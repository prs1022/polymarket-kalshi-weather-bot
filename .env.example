# Trading Bot Configuration
# Copy this to .env and fill in values

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./tradingbot.db
# DATABASE_URL=postgresql://user:pass@localhost/tradingbot

# Simulation settings
SIMULATION_MODE=true
INITIAL_BANKROLL=10000
KELLY_FRACTION=0.25
MIN_EDGE_THRESHOLD=0.08

# Live trading (Polymarket CLOB API)
LIVE_TRADING_ENABLED=false
POLYMARKET_PRIVATE_KEY=  # MetaMask private key
POLYMARKET_ADDRESS=  # Polymarket proxy wallet address (shown on PM profile)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=  # If missing, will derive from private key
LIVE_BANKROLL=0

# Kalshi API (RSA key auth for weather markets)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENABLED=true
FRED_API_KEY=
BLS_API_KEY=

# Mapbox token for map visualization (optional - demo token works)
VITE_MAPBOX_TOKEN=
